---
import type { KnowledgeCategory } from "@/types";
import type { KnowledgeTier } from "@/data/knowledgeTiers";

interface SidebarArticle {
  slug: string;
  title: string;
  sortOrder: number;
}

interface SidebarGroup {
  /** null は tier 未割当（または tier 定義のないサブカテゴリのフォールバック）を意味する */
  tier: KnowledgeTier | null;
  articles: SidebarArticle[];
}

interface Props {
  /** tier グループ化済みの記事リスト */
  groups: SidebarGroup[];
  currentSlug: string;
  categoryLabel: string;
  categorySlug: KnowledgeCategory;
  subcategorySlug?: string;
  subcategoryLabel?: string;
}

const {
  groups,
  currentSlug,
  categoryLabel,
  categorySlug,
  subcategorySlug,
  subcategoryLabel,
} = Astro.props;

const headingLabel = subcategoryLabel ?? categoryLabel;
const headingHref = subcategorySlug
  ? `/knowledge/${categorySlug}/${subcategorySlug}`
  : `/knowledge/${categorySlug}`;
const articleBasePath = subcategorySlug
  ? `/knowledge/${categorySlug}/${subcategorySlug}`
  : `/knowledge/${categorySlug}`;
const hasTiers = groups.some((g) => g.tier !== null);
---

<nav class="text-sm" aria-label={`${headingLabel} の記事一覧`}>
  <a
    href={headingHref}
    class="block text-xs font-semibold uppercase tracking-wider text-muted-foreground hover:text-teal-600 transition-colors mb-3"
  >
    {headingLabel}
  </a>
  {
    hasTiers ? (
      <div class="space-y-2">
        {groups.map((group) =>
          group.articles.length > 0 ? (
            <details
              class="knowledge-sidebar-group group/tier"
              open={
                group.tier === null ||
                group.articles.some((a) => a.slug === currentSlug)
              }
            >
              <summary class="flex items-center gap-2 cursor-pointer select-none py-1.5 text-[11px] font-bold uppercase tracking-wide text-foreground/80 hover:text-teal-600 transition-colors list-none">
                <svg
                  class="w-3 h-3 transition-transform duration-200 group-open/tier:rotate-90 flex-shrink-0"
                  viewBox="0 0 12 12"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M4 3l4 3-4 3"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                {group.tier && (
                  <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-teal-500/10 text-teal-600 text-[10px] font-semibold flex-shrink-0">
                    {group.tier.order}
                  </span>
                )}
                <span class="flex-1">
                  {group.tier ? group.tier.label : "記事一覧"}
                </span>
              </summary>
              <ol class="mt-2 ml-1.5 space-y-1 border-l border-border">
                {group.articles.map((article) => {
                  const isCurrent = article.slug === currentSlug;
                  return (
                    <li>
                      <a
                        href={`${articleBasePath}/${article.slug}`}
                        class:list={[
                          "block px-3 py-1.5 -ml-px border-l transition-colors leading-snug",
                          isCurrent
                            ? "border-teal-500 text-teal-600 font-semibold bg-teal-50/50"
                            : "border-transparent text-muted-foreground hover:text-foreground hover:border-muted-foreground/40",
                        ]}
                        aria-current={isCurrent ? "page" : undefined}
                      >
                        {article.title}
                      </a>
                    </li>
                  );
                })}
              </ol>
            </details>
          ) : null,
        )}
      </div>
    ) : (
      <ol class="space-y-1 border-l border-border">
        {groups
          .flatMap((g) => g.articles)
          .map((article) => {
            const isCurrent = article.slug === currentSlug;
            return (
              <li>
                <a
                  href={`${articleBasePath}/${article.slug}`}
                  class:list={[
                    "block px-3 py-1.5 -ml-px border-l transition-colors leading-snug",
                    isCurrent
                      ? "border-teal-500 text-teal-600 font-semibold bg-teal-50/50"
                      : "border-transparent text-muted-foreground hover:text-foreground hover:border-muted-foreground/40",
                  ]}
                  aria-current={isCurrent ? "page" : undefined}
                >
                  {article.title}
                </a>
              </li>
            );
          })}
      </ol>
    )
  }
</nav>

<style>
  /* Safari など details summary のデフォルトマーカー除去 */
  .knowledge-sidebar-group summary::-webkit-details-marker {
    display: none;
  }
  .knowledge-sidebar-group summary::marker {
    display: none;
    content: "";
  }
</style>
