---
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";

interface Props {
  title: string;
  description: string;
  category: string;
  categoryLabel: string;
  tags: string[];
  publishedAt: Date;
  href: string;
}

const { title, description, category, categoryLabel, tags, publishedAt, href } =
  Astro.props;

const formattedDate = publishedAt.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const displayTags = tags.slice(0, 3);
---

<a href={href} class="block group">
  <Card hover class="h-full">
    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-2 flex-wrap">
        <Badge variant="teal">{categoryLabel}</Badge>
        <span class="text-xs text-muted-foreground">{formattedDate}</span>
      </div>
      <h3
        class="text-lg font-semibold text-foreground group-hover:text-teal-600 transition-colors line-clamp-2"
      >
        {title}
      </h3>
      <p class="text-sm text-muted-foreground line-clamp-2">{description}</p>
      {
        displayTags.length > 0 && (
          <div class="flex gap-1.5 flex-wrap">
            {displayTags.map((tag) => (
              <Badge variant="default">{tag}</Badge>
            ))}
          </div>
        )
      }
    </div>
  </Card>
</a>
