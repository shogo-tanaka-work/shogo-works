---
import type { ServiceItem } from "@/types";
import Badge from "@/components/ui/Badge.astro";

interface Props {
  service: ServiceItem;
}

const { service } = Astro.props;
---

<section class="pt-28 pb-16">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <a href="/services" class="text-sm font-medium text-teal-700 hover:text-teal-800">
      Services に戻る
    </a>

    <div class="mt-8 grid items-start gap-10 lg:grid-cols-[1fr_20rem]">
      <div class="animate-fade-in-up">
        <p class="text-sm font-semibold tracking-wide text-teal-600">SERVICE</p>
        <h1 class="mt-4 text-3xl font-bold tracking-tight text-foreground sm:text-5xl">
          {service.title}
        </h1>
        <p class="mt-6 max-w-2xl text-base leading-relaxed text-muted-foreground sm:text-lg">
          {service.longDescription}
        </p>
        <p class="mt-5 text-sm text-muted-foreground">
          対象: {service.targetAudience}
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-xl bg-teal-500 px-6 py-3 font-medium text-white transition-colors hover:bg-teal-600"
          >
            {service.title}について問い合わせる
          </a>
          <a
            href="#details"
            class="inline-flex items-center justify-center rounded-xl bg-white px-6 py-3 font-medium text-foreground ring-1 ring-gray-950/10 transition-colors hover:bg-gray-50"
          >
            提供内容を見る
          </a>
        </div>
      </div>

      <aside class="rounded-3xl bg-white/80 p-6 shadow-sm ring-1 ring-gray-950/5">
        <h2 class="text-base font-semibold text-foreground">料金の目安</h2>
        <p class="mt-1 text-xs font-medium text-teal-600">モニター価格適用中</p>
        <div class="mt-5 space-y-4">
          {service.pricing.map((plan) => (
            <div class="border-b border-gray-100 pb-4 last:border-b-0 last:pb-0">
              <p class="text-sm font-medium text-foreground">{plan.name}</p>
              <div class="mt-2 flex items-baseline gap-2">
                {plan.monitorPrice ? (
                  <>
                    <span class="text-xl font-bold text-teal-600">{plan.monitorPrice}</span>
                    <span class="text-xs text-muted-foreground line-through">{plan.price}</span>
                  </>
                ) : (
                  <span class="text-xl font-bold text-foreground">{plan.price}</span>
                )}
              </div>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </div>
</section>

<section class="bg-gray-50/60 py-16">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold text-foreground">こんな課題を解決します</h2>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {service.painPoints.map((point) => (
        <div class="flex items-start gap-3 rounded-2xl bg-white p-5 shadow-sm ring-1 ring-gray-950/5">
          <svg class="mt-0.5 h-5 w-5 shrink-0 text-teal-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 6 9 17l-5-5" />
          </svg>
          <p class="text-sm leading-relaxed text-muted-foreground">{point}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section id="details" class="py-16 scroll-mt-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold text-foreground">提供内容</h2>
    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {service.details.map((detail) => (
        <article class="rounded-2xl bg-white/80 p-6 shadow-sm ring-1 ring-gray-950/5">
          <h3 class="font-semibold text-foreground">{detail.heading}</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{detail.body}</p>
        </article>
      ))}
    </div>

    {(service.technologies?.length || service.excludes?.length) && (
      <div class="mt-12 grid gap-8 md:grid-cols-2">
        {service.technologies && service.technologies.length > 0 && (
          <div>
            <h2 class="text-lg font-semibold text-foreground">対応技術・ツール</h2>
            <div class="mt-4 flex flex-wrap gap-2">
              {service.technologies.map((technology) => (
                <Badge variant="teal">{technology}</Badge>
              ))}
            </div>
          </div>
        )}
        {service.excludes && service.excludes.length > 0 && (
          <div>
            <h2 class="text-lg font-semibold text-foreground">対象外</h2>
            <div class="mt-4 flex flex-wrap gap-2">
              {service.excludes.map((item) => (
                <Badge variant="default">{item}</Badge>
              ))}
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</section>

<section class="pb-20 pt-4">
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <div class="rounded-3xl bg-gradient-to-br from-teal-50 via-white to-yellow-50 p-8 ring-1 ring-teal-500/10 sm:p-12">
      <h2 class="text-2xl font-bold text-foreground">
        {service.title}についてご相談ください
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-sm leading-relaxed text-muted-foreground">
        現在の課題やご希望の内容をお伺いし、対応可能な範囲をご案内します。
      </p>
      <a
        href="/contact"
        class="mt-8 inline-flex items-center justify-center rounded-xl bg-teal-500 px-6 py-3 font-medium text-white transition-colors hover:bg-teal-600"
      >
        お問い合わせへ進む
      </a>
    </div>
  </div>
</section>
