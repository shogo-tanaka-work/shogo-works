---
import { stats } from "@/data";
---

<section id="stats" class="py-20">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {stats.map((stat, index) => (
        <div
          class={`bg-white/80 ring-1 ring-gray-950/5 shadow-sm rounded-3xl p-6 text-center transition-colors group animate-on-scroll stagger-${index + 1}`}
        >
          <p class="text-3xl sm:text-4xl font-bold gradient-text mb-1">
            {stat.value}
          </p>
          <p class="text-sm font-medium text-foreground mb-1">{stat.label}</p>
          {stat.description && (
            <p class="text-xs text-muted-foreground hidden sm:block">
              {stat.description}
            </p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
