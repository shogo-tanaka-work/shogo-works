---
import { differences } from "@/data";
import SectionHeader from "@/components/ui/SectionHeader.astro";
---

<section id="difference" class="py-20">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <SectionHeader
      title="他社との違い"
      subtitle="個人だからこそ、課題から逆算して速く・継続的に伴走できます。"
    />

    <div class="space-y-4">
      {
        differences.map((item, index) => (
          <div
            class:list={[
              "grid grid-cols-1 md:grid-cols-[7rem_1fr_1fr] gap-4 md:gap-6 items-stretch animate-on-scroll",
              `stagger-${(index % 5) + 1}`,
            ]}
          >
            <div class="flex items-center font-semibold text-foreground">
              {item.aspect}
            </div>

            <div class="rounded-2xl bg-gray-50 ring-1 ring-gray-950/5 p-5">
              <div class="text-xs text-muted-foreground mb-2">一般的な外注</div>
              <p class="text-sm text-muted-foreground leading-relaxed">
                {item.others}
              </p>
            </div>

            <div class="rounded-2xl bg-teal-50 ring-1 ring-teal-500/20 p-5">
              <div class="flex items-center gap-1.5 mb-2">
                <svg
                  class="w-4 h-4 text-teal-600"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M20 6 9 17l-5-5" />
                </svg>
                <span class="text-xs font-medium text-teal-700">田中省伍</span>
              </div>
              <p class="text-sm text-foreground leading-relaxed">{item.mine}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
