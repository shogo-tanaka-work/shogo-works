---
import Button from "@/components/ui/Button.astro";
import { diagnosisCheckItems } from "@/data";

// 入口商品（無料診断）への誘導バナー。集客導線の受け皿。
// 訴求を絞るため、診断で分かることは先頭3件のみ表示する。
const highlightItems = diagnosisCheckItems.slice(0, 3);
---

<section class="py-20">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div
      class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-teal-500 to-emerald-500 px-8 py-12 sm:px-12 sm:py-14 text-white animate-on-scroll"
    >
      <div
        class="absolute -top-16 -right-16 w-64 h-64 bg-white/10 rounded-full blur-2xl"
      >
      </div>
      <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div>
          <span
            class="inline-flex items-center px-3 py-1 rounded-full bg-white/15 text-xs font-medium mb-4"
          >
            30分・オンライン・無料
          </span>
          <h2 class="text-2xl sm:text-3xl font-bold mb-3">
            まずは「AI業務改善診断」から
          </h2>
          <p class="text-white/90 leading-relaxed mb-6">
            「何にAIを使えばいいか分からない」を30分で整理します。研修・開発・顧問は、その後で合うものだけ。
          </p>
          <Button href="/diagnosis" variant="ghost" size="lg" class="bg-white text-teal-700 hover:bg-white/90">
            無料診断の詳細を見る
          </Button>
        </div>
        <ul class="space-y-3">
          {
            highlightItems.map((item) => (
              <li class="flex items-start gap-3">
                <svg
                  class="w-5 h-5 shrink-0 mt-0.5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M20 6 9 17l-5-5" />
                </svg>
                <span class="text-sm text-white/95 leading-relaxed">{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
