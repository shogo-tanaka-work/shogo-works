---
import { teachingExperience } from "@/data";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import Badge from "@/components/ui/Badge.astro";
---

<section id="teaching" class="py-20">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <SectionHeader
      title="Teaching"
      subtitle="講師実績・セミナー開催"
    />

    <!-- Timeline -->
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-teal-500/50 via-emerald-500/50 to-transparent hidden sm:block"></div>

      <div class="space-y-6">
        {teachingExperience.map((exp, index) => {
          const isClickable = exp.url && exp.url !== "#";
          const isEven = index % 2 === 0;

          return (
            <div
              class={`relative flex flex-col sm:flex-row ${
                isEven ? "sm:flex-row" : "sm:flex-row-reverse"
              } gap-4 sm:gap-8 animate-on-scroll stagger-${index + 1}`}
            >
              <!-- Timeline dot -->
              <div class="absolute left-4 md:left-1/2 top-6 w-3 h-3 rounded-full bg-teal-500 -translate-x-1.5 hidden sm:block ring-4 ring-background z-10"></div>

              <!-- Spacer -->
              <div class="hidden sm:block sm:w-1/2"></div>

              <!-- Card -->
              <div class={`sm:w-1/2 glass rounded-2xl p-5 transition-all duration-300 hover:border-teal-500/20`}>
                {isClickable ? (
                  <a href={exp.url} target="_blank" rel="noopener noreferrer" class="block">
                    <div class="flex items-start justify-between mb-2">
                      <div class="flex-1">
                        <h3 class="font-semibold text-foreground mb-1 flex items-center gap-2">
                          {exp.title}
                          <svg class="w-3.5 h-3.5 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                          </svg>
                        </h3>
                        <p class="text-sm text-teal-600">{exp.organization}</p>
                      </div>
                      <Badge variant="teal">{exp.type}</Badge>
                    </div>
                    <p class="text-sm text-muted-foreground mb-3 leading-relaxed">{exp.description}</p>
                    <div class="flex items-center gap-4 text-xs text-muted-foreground">
                      <span class="flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        {exp.period}
                      </span>
                      <span class="flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        {exp.students}名指導
                      </span>
                    </div>
                  </a>
                ) : (
                  <>
                    <div class="flex items-start justify-between mb-2">
                      <div class="flex-1">
                        <h3 class="font-semibold text-foreground mb-1">{exp.title}</h3>
                        <p class="text-sm text-teal-600">{exp.organization}</p>
                      </div>
                      <Badge variant="teal">{exp.type}</Badge>
                    </div>
                    <p class="text-sm text-muted-foreground mb-3 leading-relaxed">{exp.description}</p>
                    <div class="flex items-center gap-4 text-xs text-muted-foreground">
                      <span class="flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        {exp.period}
                      </span>
                      <span class="flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        {exp.students}名指導
                      </span>
                    </div>
                  </>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
