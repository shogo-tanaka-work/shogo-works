---
import { cn } from "@/utils/cn";

interface Props {
  variant?: "teal" | "emerald" | "blue" | "red" | "default";
  class?: string;
}

const { variant = "teal", class: className } = Astro.props;

const variants = {
  teal: "bg-teal-500/10 text-teal-600 border-teal-500/20",
  emerald: "bg-emerald-500/10 text-emerald-600 border-emerald-500/20",
  blue: "bg-blue-500/10 text-blue-600 border-blue-500/20",
  red: "bg-red-500/10 text-red-400 border-red-500/20",
  default: "bg-gray-100 text-muted-foreground border-gray-200",
};
---

<span
  class={cn(
    "px-2.5 py-1 text-xs rounded-full font-medium border",
    variants[variant],
    className
  )}
>
  <slot />
</span>
