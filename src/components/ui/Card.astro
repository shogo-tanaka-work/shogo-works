---
import { cn } from "@/utils/cn";

interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className, hover = false } = Astro.props;
---

<div
  class={cn(
    "bg-white/80 ring-1 ring-gray-950/5 shadow-sm rounded-3xl p-6 transition-all duration-300",
    hover && "hover:border-teal-500/20",
    className
  )}
>
  <slot />
</div>
