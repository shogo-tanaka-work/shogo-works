---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/ui/Button.astro";
import {
  diagnosisCheckItems,
  diagnosisSteps,
  diagnosisNextOptions,
  diagnosisFaq,
} from "@/data";

const title = "AI業務改善診断（無料） | shogoworks";
const description =
  "「何にAIを使えばいいか分からない」を30分で整理。ChatGPT活用状況チェック・業務棚卸し・導入優先順位までを無料で診断します。中小企業・製造業の経営者向け。";
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-32 pb-20">
    <div
      class="absolute top-0 -right-32 w-96 h-96 bg-gradient-to-br from-teal-200/30 via-emerald-200/20 to-blue-200/30 rounded-full blur-3xl"
    >
    </div>
    <div class="relative mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <span
        class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-teal-50 text-teal-700 text-xs font-medium ring-1 ring-teal-500/20 mb-5 animate-on-scroll"
      >
        30分・オンライン・無料
      </span>
      <h1
        class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-foreground mb-5 animate-on-scroll"
      >
        AI業務改善診断
      </h1>
      <p
        class="text-lg text-muted-foreground leading-relaxed mb-8 animate-on-scroll"
      >
        「何にAIを使えばいいか分からない」を30分で整理します。<br
          class="hidden sm:block"
        />
        活用状況チェック・業務の棚卸し・導入の優先順位まで、無料でご提案します。
      </p>
      <div
        class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll"
      >
        <Button href="/contact" size="lg">無料診断を申し込む</Button>
        <Button href="/services" variant="outline" size="lg">
          サービスを見る
        </Button>
      </div>
      <p class="text-xs text-muted-foreground mt-4 animate-on-scroll">
        ※その場で契約を迫ることはありません。
      </p>
    </div>
  </section>

  <!-- 診断で分かること -->
  <section class="py-20 bg-gray-50/50">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2
        class="text-2xl font-bold text-foreground mb-8 text-center animate-on-scroll"
      >
        この診断で分かること
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {
          diagnosisCheckItems.map((item, index) => (
            <div
              class:list={[
                "flex items-start gap-3 bg-white/80 ring-1 ring-gray-950/5 shadow-sm rounded-2xl p-5 animate-on-scroll",
                `stagger-${(index % 5) + 1}`,
              ]}
            >
              <svg
                class="w-5 h-5 shrink-0 mt-0.5 text-teal-600"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M20 6 9 17l-5-5" />
              </svg>
              <p class="text-sm text-foreground leading-relaxed">{item}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 流れ -->
  <section class="py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2
        class="text-2xl font-bold text-foreground mb-8 text-center animate-on-scroll"
      >
        診断の流れ
      </h2>
      <ol class="space-y-4">
        {
          diagnosisSteps.map((step, index) => (
            <li
              class:list={[
                "flex items-start gap-4 animate-on-scroll",
                `stagger-${(index % 5) + 1}`,
              ]}
            >
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-teal-600 text-white text-sm font-semibold flex items-center justify-center">
                {index + 1}
              </span>
              <div class="pt-1">
                <h3 class="text-base font-semibold text-foreground mb-1">
                  {step.title}
                </h3>
                <p class="text-sm text-muted-foreground leading-relaxed">
                  {step.body}
                </p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- 診断後の選択肢 -->
  <section class="py-20 bg-gray-50/50">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2
        class="text-2xl font-bold text-foreground mb-3 text-center animate-on-scroll"
      >
        診断のあとは、合うものだけ
      </h2>
      <p
        class="text-sm text-muted-foreground text-center mb-8 animate-on-scroll"
      >
        診断結果をもとに、必要であれば次のサポートへ。押し売りはしません。
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {
          diagnosisNextOptions.map((option, index) => (
            <a
              href={option.href}
              class:list={[
                "group bg-white/80 ring-1 ring-gray-950/5 shadow-sm rounded-2xl p-5 transition-all duration-300 hover:ring-teal-500/20 hover:shadow-md animate-on-scroll",
                `stagger-${(index % 5) + 1}`,
              ]}
            >
              <h3 class="text-base font-semibold text-foreground mb-2 group-hover:text-teal-700 transition-colors">
                {option.label}
              </h3>
              <p class="text-sm text-muted-foreground leading-relaxed">
                {option.description}
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2
        class="text-2xl font-bold text-foreground mb-8 text-center animate-on-scroll"
      >
        よくある質問
      </h2>
      <div class="space-y-4">
        {
          diagnosisFaq.map((item, index) => (
            <div
              class:list={[
                "bg-white/80 ring-1 ring-gray-950/5 shadow-sm rounded-2xl p-5 animate-on-scroll",
                `stagger-${(index % 5) + 1}`,
              ]}
            >
              <h3 class="text-base font-semibold text-foreground mb-2">
                Q. {item.question}
              </h3>
              <p class="text-sm text-muted-foreground leading-relaxed">
                {item.answer}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 最終CTA -->
  <section class="py-20 bg-gray-50/50">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-foreground mb-4 animate-on-scroll">
        まずは30分、話してみませんか？
      </h2>
      <p class="text-muted-foreground mb-8 animate-on-scroll">
        お問い合わせフォームに「無料診断希望」とご記入ください。日程を調整します。
      </p>
      <div class="animate-on-scroll">
        <Button href="/contact" size="lg">無料診断を申し込む</Button>
      </div>
    </div>
  </section>
</BaseLayout>
