---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import NewsCard from "@/components/ai-news/NewsCard.astro";
import ToolFilter from "@/components/ai-news/ToolFilter.astro";
import { getAiNewsSlug, getAiNewsToolCount, getPublishedAiNews } from "@/utils/aiNews";

const entries = await getCollection("aiNews");
const news = getPublishedAiNews(entries);
const counts = getAiNewsToolCount(entries);
---

<BaseLayout
  title="AI News | shogoworks"
  description="AIツールの公式アップデートを、Knowledge化する前の公開ログとして整理しています"
>
  <section class="py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <SectionHeader
        title="AI News"
        subtitle="AIツールの公式アップデートを、教材化前の公開ログとして整理しています"
      />

      <div class="mb-8 animate-on-scroll">
        <ToolFilter counts={counts} />
      </div>

      {
        news.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {news.map((entry, i) => (
              <div class={`animate-on-scroll stagger-${(i % 5) + 1}`}>
                <NewsCard
                  title={entry.data.title}
                  toolLabel={entry.data.toolLabel}
                  date={entry.data.date}
                  summary={entry.data.summary}
                  tags={entry.data.tags}
                  status={entry.data.status}
                  href={`/ai-news/${entry.data.tool}/${getAiNewsSlug(entry.id)}`}
                  sourceUrl={entry.data.sourceUrl}
                />
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-16 animate-on-scroll">
            <p class="text-muted-foreground text-lg">
              まだ公開中のAIニュースはありません。
            </p>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
