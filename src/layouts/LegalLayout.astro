---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={`${title} | shogoworks`}>
  <section class="py-20 pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-foreground mb-8">{title}</h1>
      <div class="prose prose-gray max-w-none text-muted-foreground leading-relaxed space-y-6">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>
